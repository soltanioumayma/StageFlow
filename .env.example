# ============================================================
# STAGEFLOW – VARIABLES D'ENVIRONNEMENT
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env sur Git
# ============================================================

# --- Serveur ---
PORT=5000
NODE_ENV=development

# --- Base de données PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stageflow
DB_USER=postgres
DB_PASSWORD=

# --- JWT (utiliser une clé secrète forte en production !) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=8h

# --- Email (Nodemailer via Gmail SMTP) ---
# ÉTAPES pour activer l'envoi réel :
# 1. Aller sur https://myaccount.google.com → Sécurité
# 2. Activer la validation en deux étapes
# 3. Chercher "Mots de passe des applications" → créer un mot de passe
# 4. Copier le code 16 caractères dans EMAIL_PASS ci-dessous
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=StageFlow <noreply@example.com>

# --- Upload fichiers ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# --- CORS ---
CORS_ORIGIN=http://localhost:3000
