# ============================================================
# STAGEFLOW – VARIABLES D'ENVIRONNEMENT
# Copier ce fichier et renommer en .env si besoin
# NE JAMAIS committer ce fichier sur Git
# ============================================================

# --- Serveur ---
PORT=5000
NODE_ENV=development

# --- Base de données PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stageflow
DB_USER=postgres
DB_PASSWORD=ouma

# --- JWT (changer la clé secrète en production!) ---
JWT_SECRET=stageflow_secret_key_rif_2026
JWT_EXPIRES_IN=8h

# --- Email (Nodemailer) ---
# Pour la démo, utiliser un compte Gmail avec "App Password"
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre.email@gmail.com
EMAIL_PASS=votre_app_password
EMAIL_FROM=StageFlow <votre.email@gmail.com>

# --- Upload fichiers ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
